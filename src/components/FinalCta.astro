---
---

<section id="book-a-call" class="relative overflow-hidden bg-black py-28 text-center md:py-40">
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<div class="absolute top-1/2 left-1/2 h-144 w-xl -translate-x-1/2 -translate-y-1/2 rounded-full bg-violet-ray/25 blur-3xl"></div>
		<div class="bg-noise absolute inset-0 opacity-[0.04] mix-blend-overlay"></div>

		<div
			class="absolute top-6 right-2 h-40 w-40 rotate-12 bg-violet-ray md:top-8 md:right-8 md:h-64 md:w-64"
			style="-webkit-mask-image: url(/butterflymask.webp); mask-image: url(/butterflymask.webp); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;"
		>
		</div>
		<div
			class="absolute bottom-6 left-2 h-32 w-32 -rotate-12 bg-violet-ray md:bottom-8 md:left-8 md:h-56 md:w-56"
			style="-webkit-mask-image: url(/butterflymask.webp); mask-image: url(/butterflymask.webp); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;"
		>
		</div>
	</div>

	<div class="container-page relative flex flex-col items-center">
		<h2 class="-rotate-2 max-w-3xl text-balance font-display text-4xl leading-tight font-semibold text-white md:text-6xl">
			Claim your <span class="underline decoration-[#ff0894] decoration-4 underline-offset-4">freedom</span> by
			building your remote sales career
		</h2>
		<p class="mt-6 max-w-xl text-balance text-lg leading-relaxed text-white md:text-xl">
			Join our academy for specialized training and community support, and land your first role
			in less than 30 days.
		</p>
		{/* TODO: point this at your real booking link (e.g. Calendly) */}
		<a href="#" class="btn-primary group mt-10">
			Book a call with our team
			<span
				class="btn-icon"
				style="-webkit-mask-image: url(/butterflymask.webp); mask-image: url(/butterflymask.webp); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;"
			></span>
		</a>
	</div>
</section>
