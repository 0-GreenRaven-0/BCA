---
const butterflies = [
	{ top: "3%", left: "1%", size: "1.25rem", rotate: "-11deg", opacity: 0.55 },
	{ top: "22%", left: "7%", size: "2.4rem", rotate: "-16deg", opacity: 0.8 },
	{ top: "8%", left: "13%", size: "0.8rem", rotate: "-9deg", opacity: 0.28 },
	{ top: "33%", left: "19%", size: "1.4rem", rotate: "-13deg", opacity: 0.5 },
	{ top: "1%", left: "26%", size: "1.9rem", rotate: "-10deg", opacity: 0.62 },
	{ top: "18%", left: "34%", size: "0.95rem", rotate: "-15deg", opacity: 0.38 },
	{ top: "4%", left: "39%", size: "1.6rem", rotate: "-12deg", opacity: 0.7 },
	{ top: "12%", left: "55%", size: "0.85rem", rotate: "-9deg", opacity: 0.3 },
	{ top: "6%", left: "60%", size: "1.7rem", rotate: "-14deg", opacity: 0.68 },
	{ top: "36%", left: "69%", size: "1.15rem", rotate: "-11deg", opacity: 0.42 },
	{ top: "15%", left: "76%", size: "1.95rem", rotate: "-16deg", opacity: 0.6 },
	{ top: "2%", left: "82%", size: "0.9rem", rotate: "-10deg", opacity: 0.32 },
	{ top: "24%", left: "90%", size: "1.55rem", rotate: "-13deg", opacity: 0.5 },
	{ top: "9%", left: "97%", size: "1.05rem", rotate: "-12deg", opacity: 0.4 },
];

// Offset in percentage points from center (50%). On mobile this is scaled
// down (via --lane-scale) so the wider lanes don't push the larger-relative-
// to-viewport butterflies off the edge of narrow screens; desktop uses the
// full offset for the original wide spread.
const stats = [
	{ value: "1,200+", label: "Students trained since 2023", offset: -16 },
	{ value: "87%", label: "Land their first role within 60 days", offset: 18 },
	{ value: "$8,400/mo", label: "Average income within 6 months", offset: -26 },
	{ value: "4.7/5", label: "Rating from 340+ reviews", offset: 28 },
	{ value: "$4.2M+", label: "In total alumni earnings", offset: 0 },
	{ value: "$40,000", label: "Top performer, single month", offset: -10 },
];
---

<section id="program" class="relative bg-violet-ray">
	<div id="program-pin" class="flex h-svh items-center overflow-hidden">
		<img
			src="/Bianca.png"
			alt=""
			aria-hidden="true"
			class="absolute inset-0 h-full w-full object-cover"
		/>
		<div class="pointer-events-none absolute inset-0 bg-black/40" aria-hidden="true"></div>

		<div class="pointer-events-none absolute inset-0" aria-hidden="true">
			<div class="bg-noise absolute inset-0 opacity-[0.03] mix-blend-multiply"></div>
			<div class="absolute -top-24 left-1/4 h-80 w-80 rounded-full bg-white/10 blur-3xl"></div>

			{
				butterflies.map((b) => (
					<div
						class="absolute bg-white"
						style={{
							top: b.top,
							left: b.left,
							height: b.size,
							width: b.size,
							opacity: b.opacity,
							transform: `rotate(${b.rotate})`,
							"-webkit-mask-image": "url(/butterflymask.webp)",
							"mask-image": "url(/butterflymask.webp)",
							"-webkit-mask-size": "contain",
							"mask-size": "contain",
							"-webkit-mask-repeat": "no-repeat",
							"mask-repeat": "no-repeat",
							"-webkit-mask-position": "center",
							"mask-position": "center",
						}}
					/>
				))
			}

			{
				stats.map((s, i) => (
					<div
						class="stat-butterfly absolute top-1/2 z-20 flex h-80 w-80 flex-col items-center justify-center bg-white p-4 text-center will-change-transform [--lane-scale:0.22] md:h-136 md:w-136 md:[--lane-scale:1]"
						data-index={i}
						data-total={stats.length}
						style={{
							left: `calc(50% + ${s.offset}% * var(--lane-scale))`,
							// Matches the JS-computed "local progress = 0" position
							// (fully below the section) so there's nothing to flash
							// before GSAP's first onUpdate call takes over.
							transform: "translate(-50%, calc(-50% + 65vh + 60%))",
							"-webkit-mask-image": "url(/butterfly3.webp)",
							"mask-image": "url(/butterfly3.webp)",
							"-webkit-mask-size": "contain",
							"mask-size": "contain",
							"-webkit-mask-repeat": "no-repeat",
							"mask-repeat": "no-repeat",
							"-webkit-mask-position": "center",
							"mask-position": "center",
						}}
					>
						<div class="translate-y-3 md:translate-y-6">
							<p class="font-sans text-2xl font-bold text-violet-ray md:text-4xl">{s.value}</p>
							<p class="mt-2 max-w-56 text-xs leading-snug font-bold text-violet-ray/70 md:max-w-80 md:text-base">
								{s.label}
							</p>
						</div>
					</div>
				))
			}
		</div>

		<div class="container-page relative z-10 w-full">
			<div class="mx-auto max-w-3xl text-center">
				<img
					src="/BCA2.png"
					alt="Bianca's Closer Academy"
					class="mx-auto mb-6 h-28 w-auto md:h-36"
				/>
				<h2 class="-rotate-2 text-balance font-script text-5xl leading-tight font-semibold text-white md:text-6xl">
					Bianca's Closer Academy
				</h2>
				<p class="mx-auto mt-6 text-balance text-lg leading-relaxed text-white md:text-xl">
					Made it its sole purpose to guide newbies who are absolutely green to the world of
					high-ticket remote sales and help them build a better financial life — without committing
					their time to 9-to-5s that cap their income.
				</p>
			</div>
		</div>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	// Mobile browsers fire resize events when the address bar collapses/expands
	// mid-scroll; without this, ScrollTrigger treats that as a layout change and
	// re-measures the pin, causing it to visibly jump. normalizeScroll smooths
	// out mobile scroll behavior around pinning for the same reason.
	ScrollTrigger.config({ ignoreMobileResize: true });
	ScrollTrigger.normalizeScroll(true);

	function initProgramButterflies() {
		const section = document.getElementById("program");
		const pinTarget = document.getElementById("program-pin");
		if (!section || !pinTarget) return;

		const items = Array.from(
			section.querySelectorAll<HTMLElement>(".stat-butterfly")
		);

		ScrollTrigger.create({
			trigger: section,
			start: "top top",
			end: () => `+=${window.innerHeight * items.length * 0.9}`,
			pin: pinTarget,
			scrub: true,
			invalidateOnRefresh: true,
			onUpdate: (self) => {
				const progress = self.progress;

				items.forEach((item) => {
					const index = Number(item.dataset.index);
					const total = Number(item.dataset.total);
					// Windows are wider than the step between them, so consecutive
					// butterflies' travel overlaps and two can be on screen together.
					const step = 1 / total;
					const windowSize = step * 2.6;
					const start = index * step;
					const end = start + windowSize;
					// The last window's end extends past 1, so rescale progress
					// against it — otherwise the section runs out of scroll room
					// before the final butterfly finishes exiting.
					const lastEnd = (total - 1) * step + windowSize;
					const scaledProgress = progress * lastEnd;
					const local = Math.min(Math.max((scaledProgress - start) / (end - start), 0), 1);

					// Travels from fully below the section to fully clipped out
					// above it, passing through the visible center. The offset
					// combines viewport-relative (vh) and self-relative (%)
					// clearance so it fully clears regardless of viewport height
					// or the butterfly's own size.
					const vhOffset = 65 + local * -130;
					const selfOffset = 60 + local * -120;

					gsap.set(item, {
						transform: `translate(-50%, calc(-50% + ${vhOffset}vh + ${selfOffset}%))`,
					});
				});
			},
		});
	}

	initProgramButterflies();
</script>
